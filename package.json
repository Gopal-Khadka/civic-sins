{
  "name": "civic-sense",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "predev": "pnpm assets:generate",
    "generate-routes": "tsr generate",
    "seo:generate": "node scripts/generate-seo.ts",
    "og:generate": "node scripts/generate-og.ts",
    "assets:generate": "pnpm seo:generate && pnpm og:generate",
    "prebuild": "pnpm assets:generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write",
    "lint": "biome lint",
    "check": "biome check",
    "commitlint": "commitlint",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@content-collections/core": "^0.15.1",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/vite": "^0.3.0",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "comicgen": "^1.9.9",
    "lucide-react": "^0.577.0",
    "posthog-js": "^1.386.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@netlify/vite-plugin-tanstack-start": "^1.2.15",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "gray-matter": "^4.0.3",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.9",
    "satori": "^0.26.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}